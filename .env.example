# Environment Variables Example

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database Configuration (MongoDB)
# For local-only use, leave empty.
MONGODB_URI=mongodb://localhost:27017/ceylonsky_fids

# Feature Flags
NEXT_PUBLIC_ENABLE_AUDIO=true
NEXT_PUBLIC_ENABLE_WEATHER=true

# UI Configuration
NEXT_PUBLIC_AIRPORT_NAME=CeylonSky International
NEXT_PUBLIC_TIME_FORMAT=HH:mm
